# @TODO: finish replacing the colors here


# Menu
menu.border.color: #ded0cd

menu.title.bg: Solid Flat
menu.title.bg.color: #120306
menu.title.bg.shadow: 0
menu.title.text.color: #ded0cd
menu.title.text.justify: Center

menu.items.bg: Solid Flat
menu.items.bg.color: #120306
menu.items.text.color: #ded0cd
menu.items.disabled.text.color: #ab9c9b

menu.items.active.bg: Solid Flat
menu.items.active.bg.color: #3b0d10
menu.items.active.text.color: #ded0cd

menu.separator.color: #ab9c9b
menu.separator.width: 1
menu.separator.padding.width: 2
menu.separator.padding.height: 4

# Window focused
window.active.title.separator.color: #120306

# Active window
window.active.border.color: #ded0cd


window.active.title.bg: flat solid
window.active.title.bg.color: #120306
window.active.title.separator.color: #120306
window.active.text.justify: center

window.active.label.bg: parentrelative
window.active.label.text.color: #ded0cd

window.active.handle.bg: flat solid
window.active.handle.bg.color: #120306

window.active.grip.bg: flat solid
window.active.grip.bg.color: #120306

window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #120306
window.active.button.unpressed.image.color: #ded0cd

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #3b0d10
window.active.button.pressed.image.color: #ded0cd

window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: #120306
window.active.button.disabled.image.color: #ab9c9b

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #120306
window.active.button.hover.image.color: #3b0d10

#window.active.button.toggled.bg: #3b0d10
#window.active.button.toggled.image.color: #ded0cd

# Inactive window
window.inactive.border.color: #000000

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #120306
window.inactive.title.separator.color: #120306
window.inactive.text.justify: center

window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #ab9c9b

window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #120306

window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #120306

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #120306
window.inactive.button.unpressed.image.color: #ab9c9b

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #3b0d10
window.inactive.button.pressed.image.color: #ded0cd

window.inactive.button.disabled.bg: flat solid
window.inactive.button.disabled.bg.color: #ab9c9b
window.inactive.button.disabled.image.color: #120306

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #120306
window.inactive.button.hover.image.color: #3b0d10


# OSD
osd.border.width: 1
osd.border.color: #3b0d10

osd.bg: flat solid
osd.bg.color: #120306
osd.label.bg: flat solid
osd.label.bg.color: #120306
osd.label.text.color: #ded0cd

# OSD
osd.bg: Solid Flat
osd.bg.color: #120306
osd.bg.shadow: 0

osd.border.width: 2
osd.hilight.bg: Solid Flat
osd.hilight.bg.color: #3b0d10
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #120306

osd.button.unpressed.bg: flat border
osd.button.unpressed.bg.color: #3b0d10
#osd.button.unpressed.*.border.color: #ffffff

osd.button.pressed.bg: flat border
osd.button.pressed.bg.color: #3b0d10
#osd.button.pressed.*.border.color: #ded0cd

osd.button.focused.bg: flat solid border
osd.button.focused.bg.color: #ded0cd
#osd.button.focused.*.border.color: #120306

osd.button.focused.box.color: #3b0d10


# Fonts
window.active.label.text.font:shadow=n
window.inactive.label.text.font:shadow=n
menu.items.font:shadow=n
menu.title.text.font:shadow=n


# Everything else
border.width: 3
padding.width: 8
padding.height: 3
window.handle.width: 0
window.client.padding.width: 0
window.label.text.justify: center
#menu.overlap: 0
